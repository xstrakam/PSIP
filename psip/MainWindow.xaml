<Window x:Class="psip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:psip"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,0,20">
            <Label Content="Port 1:" Width="60"/>
            <ComboBox Name="Port1ComboBox" Width="300" Margin="10,0" DisplayMemberPath="Description" />
            <Label Content="Port 2:" Width="60"/>
            <ComboBox Name="Port2ComboBox" Width="300" DisplayMemberPath="Description" />
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="90,0,70,0">
            <Button Name="StartCaptureButton" Content="Start capture" Click="StartCaptureClick" Padding="5" Margin="0, 0, 10, 0"></Button>
            <Button Name="StopCaptureButton" Content="Stop capture" Click="StopCaptureClick" Padding="5"></Button>
        </StackPanel>
        

    </Grid>
</Window>
